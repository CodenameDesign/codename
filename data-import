<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: #fff;
  color: #1A1A1A;
  width: 100%;
  max-width: 1440px;
  -webkit-font-smoothing: antialiased;
}

/* ── Browser chrome ── */
.browser-chrome {
  height: 40px;
  background: #EFEFEF;
  border-bottom: 1px solid #D8D8D8;
  display: flex; align-items: center;
  padding: 0 16px;
  position: relative;
}
.browser-dots { display: flex; gap: 7px; }
.browser-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.12);
}
.dot-r { background: #FF5F57; }
.dot-y { background: #FEBC2E; }
.dot-g { background: #28C840; }
.browser-url {
  position: absolute; left: 50%; transform: translateX(-50%);
  font-size: 12px; font-weight: 500; color: #6B6B6B;
  letter-spacing: -0.01em;
}

/* ── Navbar ── */
.navbar {
  height: 60px;
  background: #fff;
  border-bottom: 1px solid #E8E8E8;
  display: flex; align-items: center;
  padding: 0 48px;
  position: relative;
}
.navbar__brand {
  position: absolute; left: 50%; transform: translateX(-50%);
  font-size: 15px; font-weight: 700; letter-spacing: -0.03em;
  color: #1A1A1A; text-decoration: none;
}
.navbar__right {
  margin-left: auto;
  display: flex; align-items: center; gap: 14px;
}
.navbar__cart-btn {
  background: none; border: none; cursor: pointer;
  display: flex; align-items: center;
  color: #1A1A1A; padding: 4px;
}
.navbar__account {
  font-size: 13px; font-weight: 500; color: #1A1A1A;
  text-decoration: underline; text-underline-offset: 2px;
  cursor: pointer; white-space: nowrap;
}
.navbar__search {
  height: 32px; padding: 0 10px 0 32px;
  font-family: 'Inter', sans-serif; font-size: 13px;
  background: #F7F7F7; border: 1.5px solid #E8E8E8;
  border-radius: 8px; outline: none; width: 170px;
  color: #1A1A1A; position: relative;
  transition: border-color 120ms;
}
.navbar__search::placeholder { color: #9B9B9B; }
.navbar__search:focus { border-color: #FF2D87; background: #fff; }
.search-wrap {
  position: relative; display: flex; align-items: center;
}
.search-wrap svg {
  position: absolute; left: 9px; pointer-events: none;
  color: #9B9B9B;
}

/* Hamburger — hidden on desktop/laptop/tablet */
.navbar__hamburger {
  display: none;
  background: none; border: none; cursor: pointer;
  color: #1A1A1A; padding: 4px;
}

/* ── Page wrapper ── */
.page { padding: 40px 64px 0; }

/* ── Hero ── */
.hero { margin-bottom: 28px; }
.hero__title {
  font-size: 46px; font-weight: 700; letter-spacing: -0.04em;
  line-height: 1.1; color: #1A1A1A;
  margin-bottom: 20px;
  text-align: center;
}
.img-placeholder {
  background: #F4F4F4;
  border: 1px solid #E0E0E0;
  border-radius: 10px;
  position: relative; overflow: hidden;
}
.img-placeholder svg {
  width: 100%; height: 100%;
  display: block;
}
.hero__image { height: 300px; }

/* ── Body text ── */
.body-text {
  margin-bottom: 40px;
}
.body-text p {
  font-size: 14px; line-height: 1.75;
  color: #6B6B6B;
}

/* ── Product grid ── */
.product-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 18px;
  margin-bottom: 0;
  padding-bottom: 48px;
}
.product-card { display: flex; flex-direction: column; gap: 0; }
.product-card__image {
  aspect-ratio: 1 / 1;
  margin-bottom: 10px;
}
.product-card__title {
  font-size: 13px; font-weight: 600; color: #1A1A1A;
  letter-spacing: -0.01em; margin-bottom: 3px;
}
.product-card__category {
  font-size: 12px; color: #6B6B6B; margin-bottom: 4px;
}
.product-card__price {
  font-size: 13px; font-weight: 600; color: #FF2D87;
}

/* ── Footer ── */
.footer {
  background: #F7F7F7;
  border-top: 1px solid #E8E8E8;
  padding: 44px 64px 52px;
  display: grid;
  grid-template-columns: 180px 1fr 260px;
  gap: 56px;
}
.footer__col-title {
  font-size: 13px; font-weight: 700; letter-spacing: -0.01em;
  color: #1A1A1A; margin-bottom: 14px;
}
.footer__links {
  display: flex; flex-direction: column; gap: 10px;
}
.footer__link {
  font-size: 14px; color: #6B6B6B;
  text-decoration: none;
  transition: color 120ms;
}
.footer__link:hover { color: #1A1A1A; }
.footer__body {
  font-size: 13px; line-height: 1.75; color: #6B6B6B;
}
.footer__coming-image {
  width: 100%;
  aspect-ratio: 4 / 3;
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* RESPONSIVE                                                                   */
/* ─────────────────────────────────────────────────────────────────────────── */

/* ── Laptop: 1024px – 1439px ── */
@media (max-width: 1439px) {
  .page { padding: 36px 48px 0; }

  .hero__title { font-size: 42px; }
  .hero__image { height: 270px; }

  .product-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding-bottom: 40px;
  }

  .footer {
    padding: 40px 48px 44px;
    gap: 40px;
    grid-template-columns: 160px 1fr 220px;
  }
}

/* ── Tablet: 768px – 1023px ── */
@media (max-width: 1023px) {
  .navbar {
    padding: 0 32px;
    height: 56px;
  }
  .navbar__search { width: 130px; font-size: 12px; }
  .navbar__account { font-size: 12px; }
  .navbar__brand { font-size: 14px; }

  .page { padding: 28px 32px 0; }

  /* Font sizes ~15% smaller */
  .hero__title { font-size: 39px; }
  .hero__image { height: 220px; }

  .body-text { margin-bottom: 28px; }
  .body-text p { font-size: 12px; }

  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    padding-bottom: 36px;
  }
  .product-card__title   { font-size: 12px; }
  .product-card__category { font-size: 11px; }
  .product-card__price   { font-size: 12px; }

  .footer {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 28px;
    padding: 32px 32px 40px;
  }
  /* "Coming soon" spans full width on last row */
  .footer > div:last-child {
    grid-column: 1 / -1;
  }
  .footer__col-title { font-size: 12px; }
  .footer__body      { font-size: 12px; }
  .footer__link      { font-size: 12px; }
}

/* ── Mobile: up to 767px ── */
@media (max-width: 767px) {
  /* Navbar: show hamburger, hide search + account */
  .navbar {
    padding: 0 20px;
    height: 52px;
  }
  .navbar__brand { font-size: 14px; }
  .search-wrap  { display: none; }
  .navbar__account { display: none; }
  .navbar__hamburger {
    display: flex;
    align-items: center; justify-content: center;
  }
  .navbar__right { gap: 6px; }

  .page { padding: 20px 20px 0; }

  /* Font sizes ~25% smaller */
  .hero__title   { font-size: 34px; letter-spacing: -0.03em; }
  .hero__image   { height: 160px; }
  .hero          { margin-bottom: 20px; }

  .body-text { margin-bottom: 20px; }
  .body-text p { font-size: 13px; }

  /* Product grid: single column */
  .product-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    padding-bottom: 28px;
  }
  /* Landscape image ratio on single-column cards */
  .product-card__image {
    aspect-ratio: 4 / 3;
  }
  .product-card__title    { font-size: 14px; }
  .product-card__category { font-size: 12px; }
  .product-card__price    { font-size: 14px; }

  /* Footer: single column */
  .footer {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 24px 20px 32px;
  }
  .footer > div:last-child { grid-column: auto; }
  .footer__col-title { font-size: 13px; }
  .footer__body      { font-size: 13px; }
  .footer__link      { font-size: 13px; }
}
</style>
